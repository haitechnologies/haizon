# ============================================================
# LLM/AI CONTEXT EXCLUSIONS — Save tokens by excluding files
# that are runtime-only, data-heavy, or vendor/generated code.
# ============================================================

# --- Vendor & dependency directories ---
vendor/
dashboard/vendor/
node_modules/
.opencode/

# --- Heavy runtime-only config (data, not logic) ---
config/page_help_config.php
config/timezones.php
config/disposable_email_allowlist.conf
config/disposable_email_blocklist.conf
config/saas_catalog.php
config/uae_geo_constants.php

# --- Large vendor libraries bundled in dashboard ---
tcpdf/
dashboard/fullcalendar/
dashboard/assets/plugins/
dashboard/assets/custom_js/tinymce/
dashboard/assets/custom_js/jquery-ui.js
dashboard/assets/custom_js/jquery.dataTables.js
dashboard/assets/custom_js/jquery-3.6.0.js

# --- Unminified vendor JS/CSS (massive, no logic) ---
assets/js/jquery.js
assets/plugins/bootstrap/js/bootstrap.bundle.js
dashboard/assets/custom_js/jquery.inputmask.bundle.js
dashboard/assets/custom_js/jquery.datetimepicker.js
dashboard/assets/assets_custom/css/components.css
dashboard/assets/assets_custom/css/bootstrap.css
dashboard/assets/assets_custom/css/bootstrap_limitless.css
assets/css/bizdire-public-integration.css

# --- Runtime plumbing (no business logic) ---
config/globals.php
config/images.php
config/error_alerting.php
config/seo_helpers.php
config/saas_helpers.php
config/saas_generic_helpers.php
config/taxonomies_setup.php

# --- Minified files (no readable code) ---
*.min.js
*.min.css

# --- Icon/font metadata (no logic) ---
dashboard/assets/icons/
assets/fonts/
assets/iconfonts/
assets/images/
assets/video/
assets/switcher/
images/

# --- Build artifacts & lock files ---
composer.lock
dashboard/composer.lock
dashboard/composer.json

# --- Copilot/AI dev artifacts ---
.context/
.github/copilot-memory-index.md
.github/pulse-mini.md
.github/copilot-instructions.md
scratch/

# --- Logs & temp files ---
logs/
*.log
*.sql

# --- Upload directories ---
uploads/
pdfs_invoices/
backups/
data/

# --- Documentation that's not needed for code context ---
docs/llm-readability-optimization-plan.md
docs/MIGRATION-AUDIT-REMAINING.md
docs/archive/

# --- Non-essential PHP files ---
dashboard/cron_logs.php
dashboard/run_coverage_sweep.php
dashboard/view_backend_error_logs.php
dashboard/view_frontend_error_logs.php
dashboard/seo_health_check.php
