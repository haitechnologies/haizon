# ============================================================================
# SECURITY: Protect Includes / Layout Templates Directory
# ============================================================================
# Template partials are server-side PHP includes only.
# Direct access would expose layout logic and server paths.
Options -Indexes
IndexIgnore *

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
