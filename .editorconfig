root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,neon}]
indent_size = 4

[*.json]
indent_size = 4

[*.{css,scss}]
indent_size = 4

[*.js]
indent_size = 4

[Makefile]
indent_style = tab
