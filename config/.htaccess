# ============================================================================
# SECURITY: Protect Configuration Directory
# ============================================================================
# Disable directory listing
Options -Indexes
IndexIgnore *

# Deny all direct access to this directory
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>

# Block common sensitive files
<FilesMatch "\.(env|sql|log|lock|json|xml|bak|backup|php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
