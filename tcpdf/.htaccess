# ============================================================================
# SECURITY: Protect TCPDF Library Directory
# ============================================================================
# TCPDF is a server-side PDF library, not publicly accessible.
Options -Indexes
IndexIgnore *

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
