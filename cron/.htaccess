# ============================================================================
# SECURITY: Protect Cron Jobs Directory
# ============================================================================
# Cron scripts must only run via CLI/server cron scheduler.
# Web access to cron files is a remote code execution risk.
Options -Indexes
IndexIgnore *

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
